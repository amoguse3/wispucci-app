# Wispucci Backend — Environment Variables
# Copy this to .env and fill in real values

# Security
SECRET_KEY=generate-a-random-64-char-string-here
DEBUG=false

# Database (leave empty for auto-SQLite in dev)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/wispucci

# AI Tutor (OpenAI-compatible API)
# Use your own API key, or local model (Ollama, LM Studio, etc.)
AI_API_KEY=sk-your-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# CORS origins for your frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:8765,http://127.0.0.1:8765
